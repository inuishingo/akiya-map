rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /pins/{pinId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // メール→表示名の対応。手動でdoc追加運用（doc ID=メール, field name）。
    // 読み取りのみ許可。クライアントからの改変は不可。
    match /displayNames/{email} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ───────────────────────────────────────────────────────────────
    // 【案・未適用】調査グリッド進捗（feature/grid）。doc ID = gridId（例: "G_75_29"）。
    //   下のブロックは“提案”であり、まだ有効化していない（コメントアウト＝既定で deny のまま）。
    //   本番反映のタイミングはオーナー(乾)判断。デプロイ時にこのコメントを外して適用すること。
    //   surveyedBy を自分のメールに限定してなりすまし作成を防止。読み取り/更新/削除はログイン必須。
    // match /survey_grids/{gridId} {
    //   allow read:   if isSignedIn();
    //   allow create: if isSignedIn()
    //                 && request.resource.data.surveyedBy == request.auth.token.email;
    //   allow update: if isSignedIn();
    //   allow delete: if isSignedIn();
    // }
    // ───────────────────────────────────────────────────────────────
  }
}

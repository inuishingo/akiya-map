rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /pins/{pinId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // メール→表示名の対応。手動でdoc追加運用（doc ID=メール, field name）。
    // 読み取りのみ許可。クライアントからの改変は不可。
    match /displayNames/{email} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ───────────────────────────────────────────────────────────────
    // 【未適用・案】調査グリッド進捗ルール。本番コンソールでは現状コメントアウト＝未適用
    //   （＝該当パスはデフォルトdeny。グリッド保存失敗の原因である可能性あり）。
    //   別タスクで「survey_grids の実書き込み構造(コレクション/フィールド)」と本案
    //   (surveyedBy == request.auth.token.email 前提) の一致を検証し、修正後に単独deployする。
    //   反社deployにこの有効化を巻き込まないため、本番実態(未適用)に合わせて据え置き。
    // match /survey_grids/{gridId} {
    //   allow read:   if isSignedIn();
    //   allow create: if isSignedIn()
    //                 && request.resource.data.surveyedBy == request.auth.token.email;
    //   allow update: if isSignedIn()
    //                 && (resource.data.surveyedBy == request.auth.token.email || isAdmin())
    //                 && request.resource.data.surveyedBy == resource.data.surveyedBy;
    //   allow delete: if isSignedIn()
    //                 && (resource.data.surveyedBy == request.auth.token.email || isAdmin());
    // }
    // ───────────────────────────────────────────────────────────────
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /pins/{pinId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // メール→表示名の対応。手動でdoc追加運用（doc ID=メール, field name）。
    // 読み取りのみ許可。クライアントからの改変は不可。
    match /displayNames/{email} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ───────────────────────────────────────────────────────────────
    // 調査グリッド進捗（survey_grids）。doc ID = "G_{row}_{col}"（index.html toggleGridCell）。
    //   書込構造と一致を検証済み：create時 surveyedBy = currentUser.email（= token.email）。
    //   解除(delete)は本人 or admin 限定。update は所有者/admin かつ surveyedBy 不変（なりすまし防止）。
    //   ※コメントアウト時は該当パスがデフォルトdeny＝グリッド保存失敗の原因。単独deployで有効化。
    match /survey_grids/{gridId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.surveyedBy == request.auth.token.email;
      allow update: if isSignedIn()
                    && (resource.data.surveyedBy == request.auth.token.email || isAdmin())
                    && request.resource.data.surveyedBy == resource.data.surveyedBy;
      allow delete: if isSignedIn()
                    && (resource.data.surveyedBy == request.auth.token.email || isAdmin());
    }
    // ───────────────────────────────────────────────────────────────
  }
}
